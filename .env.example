# Copy this file to .env and adjust as needed for local development.
# docker-compose.yml sets these directly for the consumer/simulator
# containers - this file is for running main.py / consumer.py on the
# host (outside Docker), matching README.md's quick start.

# --- Kafka ---
# Use localhost:9092 (EXTERNAL listener) when running on the host.
# Use kafka:29092 (INTERNAL listener) only from inside the compose network.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
TELEMETRY_TOPIC=scara.telemetry.v1
MACHINE_ID=foam_placement_01

# --- main.py (simulator) ---
SCAN_INTERVAL_SECONDS=0.5

# --- consumer.py ---
CONSUMER_GROUP_ID=foam-placement-consumer
BATCH_MAX_SIZE=50
BATCH_MAX_SECONDS=2.0

# --- TimescaleDB ---
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_DB=foam_placement
TIMESCALE_USER=foam_admin
TIMESCALE_PASSWORD=foam_admin_pw
