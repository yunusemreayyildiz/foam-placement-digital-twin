{
  "title": "Foam Placement Machine - Predictive Maintenance",
  "uid": "foam-placement-analytics",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Cycle Time Trend with Control Limits",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "linear" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT cycle_end_time AS \"time\", cycle_duration_seconds AS \"cycle_duration_seconds\", ewma_cycle_duration AS \"ewma\", ewma_cycle_duration + 3 * ewma_stddev_cycle_duration AS \"upper_limit_3sigma\", ewma_cycle_duration - 3 * ewma_stddev_cycle_duration AS \"lower_limit_3sigma\" FROM cycle_metrics ORDER BY cycle_end_time;",
          "rawQuery": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Anomaly Score Over Time (IsolationForest)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT cycle_end_time AS \"time\", ml_anomaly_score AS \"ml_anomaly_score\" FROM cycle_metrics WHERE ml_anomaly_score IS NOT NULL ORDER BY cycle_end_time;",
          "rawQuery": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Flagged Anomalous Cycles",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "cycle_end_time", "desc": true }]
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT cycle_end_time, cycle_duration_seconds, had_red_handling, stat_anomaly_flag, ml_anomaly_flag, ml_anomaly_score FROM cycle_metrics WHERE stat_anomaly_flag IS TRUE OR ml_anomaly_flag IS TRUE ORDER BY cycle_end_time DESC LIMIT 20;",
          "rawQuery": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Rolling Error Rate (last 10 cycles)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT cycle_end_time AS \"time\", AVG(CASE WHEN had_red_handling THEN 1.0 ELSE 0.0 END) OVER (ORDER BY cycle_end_time ROWS BETWEEN 9 PRECEDING AND CURRENT ROW) AS \"rolling_error_rate\" FROM cycle_metrics ORDER BY cycle_end_time;",
          "rawQuery": true
        }
      ]
    }
  ]
}
